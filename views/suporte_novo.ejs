<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Orbic | Novo Chamado</title>
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(0, 242, 255, 0.2);
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 20px;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-label {
            display: block;
            color: var(--primary);
            font-family: 'Space Grotesk', sans-serif;
            margin-bottom: 8px;
            font-size: 0.9rem;
            letter-spacing: 1px;
        }
        
        .form-control {
            width: 100%;
            padding: 12px 15px;
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            color: #fff;
            font-family: 'Inter', sans-serif;
            outline: none;
            transition: 0.3s;
        }
        
        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 10px rgba(0, 242, 255, 0.2);
        }
        
        .radio-group {
            display: flex;
            gap: 20px;
        }
        
        .radio-option {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
        }

        .btn-submit {
            padding: 12px 30px;
            background: var(--primary);
            color: #000;
            border: none;
            border-radius: 4px;
            font-family: 'Space Grotesk', sans-serif;
            font-weight: bold;
            text-transform: uppercase;
            cursor: pointer;
            transition: 0.3s;
            display: inline-block;
        }
        
        .btn-submit:hover {
            box-shadow: 0 0 20px var(--primary);
            transform: scale(1.02);
        }

        .calendar-container {
            width: 100%;
            height: 400px;
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(0,0,0,0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-dim);
            text-align: center;
        }
        
        .two-cols {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
        }
        
        @media (max-width: 768px) {
            .two-cols {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body class="tech-bg">

    <div id="cursor"></div>
    <div id="cursor-dot"></div>

    <main class="container" style="padding: 100px 10%;">
        <header style="margin-bottom: 40px;">
            <h1 style="font-family: 'Space Grotesk', sans-serif; color: #fff;">Abrir Novo Chamado</h1>
            <p style="color: #888;">Selecione a urgência, o tipo de atendimento e o horário desejado.</p>
            <br>
            <a href="/suporte" style="color: var(--text-dim); text-decoration: none;">← Voltar para Central</a>
        </header>

        <div class="two-cols">
            <!-- Coluna 1: Formulário -->
            <div class="glass-card">
                <form action="/suporte/novo" method="POST">
                    
                    <!-- Simulação Google Auth -->
                    <div class="form-group">
                        <span class="form-label">USUÁRIO IDENTIFICADO (Google Auth)</span>
                        <div style="padding: 10px; background: rgba(0,242,255,0.05); border: 1px dashed var(--primary); border-radius: 4px; font-size: 0.85rem; color: #aaa;">
                            Autenticado via Gmail corporativo. <br>
                            Empresa detectada: <strong style="color: var(--primary);">Zents</strong>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">TIPO DE ATENDIMENTO</label>
                        <div class="radio-group">
                            <label class="radio-option">
                                <input type="radio" name="tipo" value="remoto" checked> Remoto
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="tipo" value="inloco"> In-Loco
                            </label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">NÍVEL DE URGÊNCIA</label>
                        <select class="form-control" name="urgencia">
                            <option value="baixa">Baixa (Padrão)</option>
                            <option value="media">Média (Até 24h)</option>
                            <option value="alta" style="color: #ff3366;">Alta (Crítico / Imediato)</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">DESCRIÇÃO DO PROBLEMA</label>
                        <textarea class="form-control" name="descricao" rows="4" placeholder="Descreva o que está acontecendo detalhadamente..."></textarea>
                    </div>

                    <button type="submit" class="btn-submit">Registrar Chamado</button>
                </form>
            </div>

            <!-- Coluna 2: Calendário Futurista -->
            <div class="glass-card">
                <h3 style="color: var(--primary); font-family: 'Space Grotesk', sans-serif; margin-bottom: 15px;">Disponibilidade</h3>
                <p style="font-size: 0.9rem; margin-bottom: 20px; color: var(--text-dim);">Escolha um horário livre na agenda técnica.</p>
                
                <div class="calendar-container">
                    <!-- Placeholder para o Google Calendar -->
                    <div>
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" style="margin-bottom: 10px;">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                        <br>
                        [Iframe do Google Calendar Aqui]
                        <br><br>
                        <span style="font-size: 0.7rem; border: 1px solid var(--primary); padding: 4px 10px; border-radius: 12px; color: var(--primary); font-weight: bold; text-transform: uppercase;">Integração API</span>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <script src="/js/main.js"></script>
</body>
</html>
