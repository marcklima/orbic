<!-- views/admin_listagem.ejs -->
<!DOCTYPE html>
<html lang="pt-br" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ORBIC | Biblioteca Listagem</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Space+Grotesk:wght@300;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    
    <style>
        /* ========================================================
           CORREÇÃO DO MOUSE E BLOCOS DE OVERLAY
           ======================================================== */
        * { cursor: auto !important; } 
        button, a, select, input[type="file"], .btn-ai, tr { cursor: pointer !important; }
        
        /* Oculta os custom cursors estáticos que podem estar invisíveis barrando clicks */
        #cursor, #cursor-dot, .cursor-overlay { 
            display: none !important; 
            pointer-events: none !important; 
        }

        /* ========================================================
           CSS ESSENCIAL ORBIC (INCORPORADO PARA FUNCIONAR LOCAL / OFFLINE SEM O BLOQUEIO DE CDN)
           ======================================================== */
        * { box-sizing: border-box; }
        body { margin: 0; background-color: #0b0f19; color: #ffffff; font-family: 'Inter', sans-serif; }
        h1, h2, h3, h4, h5, h6 { font-family: 'Space Grotesk', sans-serif; }
        
        .container { width: 100%; padding-right: 15px; padding-left: 15px; margin-right: auto; margin-left: auto; max-width: 1000px; }
        .my-5 { margin-top: 3rem; margin-bottom: 3rem; }
        .pt-5 { padding-top: 3rem; }
        .mb-4 { margin-bottom: 1.5rem; }
        .mt-5 { margin-top: 3rem; }
        .text-center { text-align: center; }
        .d-flex { display: flex; }
        .justify-content-between { justify-content: space-between; }
        .align-items-center { align-items: center; }
        .text-decoration-none { text-decoration: none; }
        .fw-bold { font-weight: bold; }
        .text-muted { color: #6c757d; }
        .w-100 { width: 100%; }
        
        /* Grid nativo para não precisar do CDN */
        .row { display: flex; flex-wrap: wrap; margin-right: -15px; margin-left: -15px; gap: 15px 0;}
        .col-12 { flex: 0 0 100%; max-width: 100%; position: relative; width: 100%; padding-right: 15px; padding-left: 15px; }

        /* Sistema de Alertas */
        .alert { padding: 1rem 1rem; margin-bottom: 1rem; border: 1px solid transparent; border-radius: 0.25rem; font-weight: 500;}
        .alert-danger { color: #ffffff; background-color: rgba(220, 53, 69, 0.4); border-color: #dc3545; border-left: 5px solid #dc3545;}
        .alert-success { color: #ffffff; background-color: rgba(25, 135, 84, 0.4); border-color: #198754; border-left: 5px solid #198754;}
        
        /* Tema Administrativo - Glassmorphism */
        .admin-glass-card {
            background: rgba(15, 23, 42, 0.9); 
            backdrop-filter: blur(12px);
            border: 1px solid rgba(0, 255, 255, 0.15);
            border-radius: 16px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
            padding: 2.5rem;
            position: relative;
            overflow: hidden;
            margin-bottom: 2rem;
            z-index: 10;
        }

        .admin-glass-card::before {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 3px;
            background: linear-gradient(90deg, #0b0f19, #00ffff, #0055ff, #0b0f19);
        }

        /* Tabela */
        table {
            width: 100%;
            border-collapse: collapse;
            color: #fff;
            margin-top: 1rem;
        }
        
        table th, table td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        table th {
            background-color: rgba(0, 0, 0, 0.5);
            font-weight: 600;
            color: #00ffff;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
        }

        table tr:hover {
            background-color: rgba(255, 255, 255, 0.05);
        }

        /* Botões Ação IA e Tabela */
        .btn-ai {
            background: linear-gradient(135deg, #0055ff, #00ffff); border: none; color: #0b0f19;
            font-weight: 700; padding: 10px 20px; border-radius: 8px; font-size: 0.9rem;
            text-transform: uppercase; letter-spacing: 0.5px; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: inline-block;
            text-decoration: none;
        }

        .btn-ai:hover {
            transform: translateY(-2px); box-shadow: 0 8px 15px rgba(0, 255, 255, 0.3);
            color: #ffffff; background: linear-gradient(135deg, #00ffff, #0055ff);
        }

        .btn-danger {
            background: linear-gradient(135deg, #dc3545, #ff4d4d);
            border: none; color: #fff; font-weight: 600; padding: 6px 12px; border-radius: 6px;
            font-size: 0.8rem; transition: all 0.3s ease;
        }
        
        .btn-danger:hover {
            transform: translateY(-2px); box-shadow: 0 4px 10px rgba(220, 53, 69, 0.4);
        }
        
        .btn-info {
            background: linear-gradient(135deg, #17a2b8, #0dcaf0);
            border: none; color: #0b0f19; font-weight: 600; padding: 6px 12px; border-radius: 6px;
            font-size: 0.8rem; text-decoration: none; transition: all 0.3s ease;
        }

        .btn-info:hover {
            transform: translateY(-2px); box-shadow: 0 4px 10px rgba(23, 162, 184, 0.4); color: #fff;
        }

        .text-cyan { color: #00ffff !important; }
        
        .table-responsive {
            overflow-x: auto;
            border-radius: 8px;
        }

        /* Filtros e Paginação */
        .controls-container {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 1rem; gap: 15px; flex-wrap: wrap;
        }
        .search-input {
            flex: 1; min-width: 250px; padding: 0.75rem 1rem; font-size: 1rem;
            color: #fff; background-color: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 0.375rem;
            outline: none; transition: all 0.3s ease;
        }
        .search-input:focus {
            border-color: #00ffff; box-shadow: 0 0 0 0.2rem rgba(0, 255, 255, 0.15);
        }
        .per-page-select {
            padding: 0.75rem 1.5rem 0.75rem 1rem; background-color: rgba(0, 0, 0, 0.5); color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 0.375rem;
            outline: none; cursor: pointer;
        }
        .per-page-select option { background: #0b0f19; }

        .pagination-controls {
            display: flex; justify-content: flex-end; align-items: center;
            margin-top: 1.5rem; gap: 10px;
        }
        .pagination-btn {
            background-color: rgba(0, 0, 0, 0.5); color: #00ffff;
            border: 1px solid rgba(0, 255, 255, 0.3); padding: 8px 16px; border-radius: 6px;
            cursor: pointer; transition: all 0.3s; font-weight: 600;
        }
        .pagination-btn:hover:not(:disabled) { background-color: rgba(0, 255, 255, 0.1); }
        .pagination-btn:disabled { color: #6c757d; border-color: rgba(255, 255, 255, 0.1); cursor: not-allowed !important; }
        .pagination-info { font-size: 0.9rem; color: #a0aec0; }

        /* Modal Customizado */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            background: rgba(11, 15, 25, 0.85); backdrop-filter: blur(8px);
            display: flex; align-items: center; justify-content: center;
            z-index: 9999; opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
        }
        .modal-overlay.active { opacity: 1; pointer-events: auto; }
        
        .modal-content {
            background: #0f172a; border: 1px solid rgba(0, 255, 255, 0.2); border-radius: 16px;
            width: 90%; max-width: 700px; max-height: 90vh; overflow-y: auto;
            padding: 2.5rem; position: relative; transform: translateY(-30px);
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 15px 50px rgba(0,0,0,0.6);
        }
        .modal-overlay.active .modal-content { transform: translateY(0); }
        
        .modal-close {
            position: absolute; top: 1.2rem; right: 1.5rem; font-size: 1.8rem;
            background: none; border: none; color: #a0aec0; cursor: pointer; transition: color 0.2s;
            line-height: 1;
        }
        .modal-close:hover { color: #ff4d4d; }
        
        .modal-header { border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 1rem; margin-bottom: 1.5rem; }
        .modal-header h3 { margin: 0; color: #00ffff; font-weight: 700; font-family: 'Space Grotesk', sans-serif;}
        
        .modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
        .modal-full-width { grid-column: 1 / -1; }
        
        .detail-item { display: flex; flex-direction: column; }
        .detail-label { font-size: 0.8rem; color: #a0aec0; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.4rem; }
        .detail-value { font-size: 0.95rem; color: #e2e8f0; background: rgba(0,0,0,0.4); padding: 0.8rem 1rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05); min-height: 42px;}
        
        /* Ajustar scrollbar do modal */
        .modal-content::-webkit-scrollbar { width: 8px; }
        .modal-content::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); border-radius: 8px; }
        .modal-content::-webkit-scrollbar-thumb { background: rgba(0,255,255,0.2); border-radius: 8px; }
        .modal-content::-webkit-scrollbar-thumb:hover { background: rgba(0,255,255,0.4); }
    </style>
</head>
<body>

    <%- include('partials/navbar') %>

    <main class="container my-5 pt-5">
        <div class="row justify-content-center">
            <div class="col-12">
                
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <a href="/admin/upload" class="text-decoration-none text-cyan fw-bold">
                        ← Voltar para Dashboard
                    </a>
                    <a href="/admin/upload" class="btn-ai">
                        + Cadastrar Novo
                    </a>
                </div>

                <div class="admin-glass-card">
                    <div class="text-center mb-4">
                        <h2 class="text-cyan fw-bold">Biblioteca Orbic</h2>
                        <p class="text-muted">Gestão integrada do acervo de conhecimento RAG da plataforma.</p>
                    </div>

                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="alert alert-danger" role="alert">
                            <strong>Erro:</strong> <%= error %>
                        </div>
                    <% } %>

                    <!-- Filtros -->
                    <div class="controls-container">
                        <input type="text" id="searchInput" class="search-input" placeholder="Pesquisar por título ou autor..." autocomplete="off">
                        <select id="perPageSelect" class="per-page-select">
                            <option value="5">5 por página</option>
                            <option value="10" selected>10 por página</option>
                            <option value="15">15 por página</option>
                            <option value="20">20 por página</option>
                        </select>
                    </div>

                    <div class="table-responsive">
                        <table id="dataTable">
                            <thead>
                                <tr>
                                    <th>Título</th>
                                    <th>Autor</th>
                                    <th>Categoria</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody id="tableBody">
                                <% if (livros && livros.length > 0) { %>
                                    <% livros.forEach(livro => { %>
                                        <tr class="data-row" data-titulo="<%= (livro.titulo || '').toLowerCase() %>" data-autor="<%= (livro.autor || '').toLowerCase() %>">
                                            <td><%= livro.titulo %></td>
                                            <td><%= livro.autor %></td>
                                            <td><span style="background: rgba(0,255,255,0.1); color: #00ffff; padding: 4px 8px; border-radius: 4px; font-size: 0.8rem;"><%= livro.categoria %></span></td>
                                            <td>
                                                <div class="d-flex align-items-center" style="gap: 10px;">
                                                    <button type="button" class="btn-info open-modal-btn" 
                                                        data-titulo="<%= livro.titulo %>"
                                                        data-autor="<%= livro.autor %>"
                                                        data-categoria="<%= livro.categoria %>"
                                                        data-editora="<%= livro.editora || '-' %>"
                                                        data-ano="<%= livro.ano_edicao || '-' %>"
                                                        data-isbn="<%= livro.isbn || '-' %>"
                                                        data-palavras="<%= Array.isArray(livro.palavras_chave) ? livro.palavras_chave.join(', ') : (livro.palavras_chave || '-') %>"
                                                        data-descricao="<%= livro.descricao || 'Sem resumo disponível.' %>">
                                                        Detalhes
                                                    </button>
                                                    
                                                    <form action="/admin/delete/<%= livro.id %>" method="POST" onsubmit="return confirm('Tem certeza que deseja excluir a obra <%= livro.titulo.replace(/'/g, "\\'") %>? Esta ação é irreversível.')" style="margin: 0;">
                                                        <button type="submit" class="btn-danger">Excluir</button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr id="emptyRow">
                                        <td colspan="4" class="text-center" style="padding: 30px; color: #6c757d;">
                                            Nenhuma obra registrada na base de dados no momento.
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Paginação -->
                    <div class="pagination-controls" id="paginationControls">
                        <span class="pagination-info" id="paginationInfo">Mostrando 0-0 de 0</span>
                        <button class="pagination-btn" id="btnPrev" disabled>Anterior</button>
                        <button class="pagination-btn" id="btnNext" disabled>Próxima</button>
                    </div>

                </div>
            </div>
        </div>
    </main>

    <!-- Modal HTML (Detalhes Obra) -->
    <div class="modal-overlay" id="detailsModal">
        <div class="modal-content">
            <button class="modal-close" id="closeModalBtn">&times;</button>
            <div class="modal-header">
                <h3 id="modTitulo">Título do Livro</h3>
            </div>
            <div class="modal-grid">
                <div class="detail-item">
                    <span class="detail-label">Autor(es)</span>
                    <div class="detail-value" id="modAutor">-</div>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Categoria (Módulo)</span>
                    <div class="detail-value" id="modCat">-</div>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Editora</span>
                    <div class="detail-value" id="modEdit">-</div>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Ano/Edição</span>
                    <div class="detail-value" id="modAno">-</div>
                </div>
                <div class="detail-item">
                    <span class="detail-label">ISBN</span>
                    <div class="detail-value" id="modIsbn">-</div>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Palavras-chave</span>
                    <div class="detail-value" id="modTag">-</div>
                </div>
                <div class="detail-item modal-full-width">
                    <span class="detail-label">Resumo e Diretrizes de Foco para IA</span>
                    <div class="detail-value" id="modDesc" style="white-space: pre-wrap;">-</div>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

    <!-- Scripts de Interação UI e Dados -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // ==========================================
            // LÓGICA DO MODAL
            // ==========================================
            const modal = document.getElementById('detailsModal');
            const btnClose = document.getElementById('closeModalBtn');

            function fecharModal() {
                modal.classList.remove('active');
            }

            btnClose.addEventListener('click', fecharModal);
            
            modal.addEventListener('click', (e) => {
                if(e.target === modal) fecharModal();
            });
            
            document.addEventListener('keydown', (e) => {
                if(e.key === 'Escape' && modal.classList.contains('active')) fecharModal();
            });

            // Atrelar click aos botões de detalhes usando dataset
            function bindModalButtons() {
                document.querySelectorAll('.open-modal-btn').forEach(btn => {
                    btn.addEventListener('click', function() {
                        const dados = this.dataset;
                        document.getElementById('modTitulo').innerText = dados.titulo;
                        document.getElementById('modAutor').innerText = dados.autor;
                        document.getElementById('modCat').innerText = dados.categoria;
                        document.getElementById('modEdit').innerText = dados.editora;
                        document.getElementById('modAno').innerText = dados.ano;
                        document.getElementById('modIsbn').innerText = dados.isbn;
                        document.getElementById('modTag').innerText = dados.palavras;
                        document.getElementById('modDesc').innerText = dados.descricao;
                        
                        modal.classList.add('active');
                    });
                });
            }

            // ==========================================
            // LÓGICA DE PESQUISA E PAGINAÇÃO
            // ==========================================
            const searchInput = document.getElementById('searchInput');
            const perPageSelect = document.getElementById('perPageSelect');
            const rows = Array.from(document.querySelectorAll('.data-row'));
            
            const btnPrev = document.getElementById('btnPrev');
            const btnNext = document.getElementById('btnNext');
            const paginationInfo = document.getElementById('paginationInfo');
            const tableBody = document.getElementById('tableBody');
            const emptyRow = document.getElementById('emptyRow');

            let currentPage = 1;
            let itemsPerPage = parseInt(perPageSelect.value);
            let filteredRows = [...rows];

            function renderTable() {
                // Esconder todos inicialmente
                rows.forEach(row => row.style.display = 'none');
                
                // Tratar estado vazio
                const dynamicEmptyRow = document.getElementById('dynamicEmptyRow');
                if (filteredRows.length === 0) {
                    if(!emptyRow && rows.length > 0 && !dynamicEmptyRow) {
                        const tr = document.createElement('tr');
                        tr.id = 'dynamicEmptyRow';
                        tr.innerHTML = '<td colspan="4" class="text-center" style="padding: 30px; color: #6c757d;">Nenhum resultado encontrado para a pesquisa.</td>';
                        tableBody.appendChild(tr);
                    } else if (dynamicEmptyRow) {
                        dynamicEmptyRow.style.display = 'table-row';
                    }
                    if(emptyRow) emptyRow.style.display = 'table-row';
                    
                    paginationInfo.innerText = `Mostrando 0-0 de 0`;
                    btnPrev.disabled = true;
                    btnNext.disabled = true;
                    return;
                } else {
                    if (dynamicEmptyRow) dynamicEmptyRow.style.display = 'none';
                    if (emptyRow) emptyRow.style.display = 'none';
                }

                // Cálculo das páginas
                const totalItems = filteredRows.length;
                const totalPages = Math.ceil(totalItems / itemsPerPage);
                
                if (currentPage > totalPages) currentPage = totalPages;
                if (currentPage < 1) currentPage = 1;

                const startIdx = (currentPage - 1) * itemsPerPage;
                const endIdx = Math.min(startIdx + itemsPerPage, totalItems);

                // Exibir apenas as linhas do range exato
                for(let i = startIdx; i < endIdx; i++){
                    filteredRows[i].style.display = 'table-row';
                }

                // Controles e labels
                paginationInfo.innerText = `Mostrando ${startIdx + 1}-${endIdx} de ${totalItems}`;
                btnPrev.disabled = currentPage === 1;
                btnNext.disabled = currentPage === totalPages || totalPages === 0;
            }

            // Bind Events
            searchInput.addEventListener('input', (e) => {
                const term = e.target.value.toLowerCase().trim();
                if(term === '') {
                    filteredRows = [...rows];
                } else {
                    filteredRows = rows.filter(row => {
                        return row.dataset.titulo.includes(term) || row.dataset.autor.includes(term);
                    });
                }
                currentPage = 1; 
                renderTable();
            });

            perPageSelect.addEventListener('change', (e) => {
                itemsPerPage = parseInt(e.target.value);
                currentPage = 1;
                renderTable();
            });

            btnPrev.addEventListener('click', () => {
                if(currentPage > 1) {
                    currentPage--;
                    renderTable();
                }
            });

            btnNext.addEventListener('click', () => {
                const totalPages = Math.ceil(filteredRows.length / itemsPerPage);
                if(currentPage < totalPages) {
                    currentPage++;
                    renderTable();
                }
            });

            // Inicialização Nativa
            if(rows.length > 0) {
                renderTable();
                bindModalButtons();
            }
        });
    </script>
    <script src="/js/main.js"></script>
</body>
</html>
