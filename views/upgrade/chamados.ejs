<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ORBIC | Dashboard de Suporte</title>
    <!-- CSS Global (Navbar e Footer) -->
    <link rel="stylesheet" href="/css/main.css">
    <!-- CSS Específico do Painel -->
    <link rel="stylesheet" href="/css/upgrade.css">
    
    <style>
        /* Customizações de UI para Select e Layout de 2 colunas */
        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            max-width: 1400px;
            margin: 40px auto;
            padding: 0 5%;
        }

        /* Estilização Moderna dos Selects */
        select.form-control {
            appearance: none;
            background-color: rgba(0, 0, 0, 0.7) !important;
            color: #fff !important;
            border: 1px solid rgba(0, 242, 255, 0.3) !important;
            padding: 12px 15px;
            border-radius: 8px;
            cursor: pointer;
        }
        
        select.form-control option {
            background-color: #111; /* Remove fundo branco nativo */
            color: #fff;
            padding: 10px;
        }

        /* Cores Removidas das Options e movidas apenas para o Badges (A pedido do User) */

        /* Estilos do Histórico (Timeline) */
        .history-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            transition: 0.3s;
        }
        .history-card:hover {
            border-color: rgba(0, 242, 255, 0.3);
            transform: translateY(-2px);
        }

        .status-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: bold;
            text-transform: uppercase;
        }

        /* Mapeamento visual Intuitivo dos Status */
        .status-recebido { background: rgba(255, 255, 255, 0.1); color: #ccc; border: 1px solid #aaa; }
        .status-em_andamento { background: rgba(255, 255, 255, 0.2); color: #fff; border: 1px solid #fff; }
        .status-pendente_cliente { background: rgba(255, 204, 0, 0.1); color: #ffcc00; border: 1px solid #ffcc00; }
        .status-atrasado { background: rgba(255, 51, 102, 0.1); color: #ff3366; border: 1px solid #ff3366; }
        .status-resolvido { background: rgba(51, 170, 51, 0.1); color: #33aa33; border: 1px solid #33aa33; }
        
        @media (max-width: 900px) {
            .dashboard-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body class="upgrade-theme-scope tech-bg">

    <%- include('../partials/navbar') %>

    <div class="dashboard-grid">
        
        <!-- LADO ESQUERDO: ABERTURA DE CHAMADOS & CALENDÁRIO -->
        <div class="form-column">
            <h2 style="font-family: 'Space Grotesk', sans-serif; font-size: 2rem; margin-bottom: 5px; color: #fff;">Novo Chamado</h2>
            <p style="color: #aaa; margin-bottom: 30px;">Relate o problema para a equipe de engenharia.</p>

            <form action="/api/chamados" method="POST" enctype="multipart/form-data" class="itil-card">
                
                <div class="form-group">
                    <label class="form-label">TIPO DE SOLICITAÇÃO</label>
                    <select name="tipo" class="form-control" required>
                        <option value="" disabled selected>Selecione o tipo...</option>
                        <option value="incidente">Problema / Erro (Incidente)</option>
                        <option value="requisicao">Novo Pedido / Dúvida (Requisição)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">CATEGORIA</label>
                    <select name="categoria" class="form-control" required>
                        <option value="" disabled selected>Qual área isso afeta?</option>
                        <option value="infra">Infraestrutura e Servidores</option>
                        <option value="software">Sistema ou Regra de Negócio</option>
                        <option value="interface">Design ou Layout da Tela</option>
                        <option value="api">Integração (n8n, IA, etc)</option>
                        <option value="acessos">Login e Acessos</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">RESUMO DO PROBLEMA</label>
                    <input type="text" name="titulo" class="form-control" placeholder="Ex: Erro ao logar no sistema" required>
                </div>

                <div class="form-group">
                    <label class="form-label">DESCRIÇÃO DETALHADA</label>
                    <textarea name="descricao" class="form-control" rows="4" placeholder="Como o problema acontece? Quais passos você fez?" required></textarea>
                </div>

                <div class="priority-grid">
                    <div class="form-group">
                        <label class="form-label">IMPACTO (Pessoas)</label>
                        <select id="impacto" name="impacto" class="form-control" onchange="calcularPrioridade()" required>
                            <option value="3">Baixo (Afeta só a mim)</option>
                            <option value="2">Médio (Afeta uma equipe inteira)</option>
                            <option value="1">Alto (Empresa toda parada)</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">URGÊNCIA (Tempo)</label>
                        <select id="urgencia" name="urgencia" class="form-control" onchange="calcularPrioridade()" required>
                            <option value="3">Baixa (Pode ser na próxima semana)</option>
                            <option value="2">Média (Preciso resolver entre hoje/amanhã)</option>
                            <option value="1">Alta (Tem que ser agora, crítico)</option>
                        </select>
                    </div>
                </div>

                <div class="form-group" style="background: rgba(0,0,0,0.6); padding: 15px; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; border: 1px solid rgba(255,255,255,0.1);">
                    <div>
                        <strong style="color: var(--brand-upgrade); font-family: 'Space Grotesk', sans-serif;">NÍVEL DO ATENDIMENTO</strong>
                    </div>
                    <div id="badge-prioridade" style="padding: 6px 15px; border-radius: 4px; font-weight: bold; font-family: 'Space Grotesk', sans-serif; background: #333; color: #fff;">
                        P4 - Planejado
                    </div>
                    <input type="hidden" id="input-prioridade" name="prioridade" value="P4">
                </div>

                <!-- Agenda Nativa Simples -->
                <div class="form-group" style="margin-top: 30px;">
                    <label class="form-label">SUGESTÃO DE HORÁRIO (Opcional)</label>
                    <p style="font-size: 0.8rem; color: #888; margin-bottom: 10px;">Se o problema requer acesso à sua máquina (acesso remoto), escolha um dia e hora que você estará disponível.</p>
                    <input type="datetime-local" name="data_agendamento" class="form-control">
                </div>

                <button type="submit" class="btn-submit" style="width: 100%; margin-top: 20px;">Registrar Chamado</button>
            </form>
        </div>

        <!-- LADO DIREITO: HISTÓRICO DE CHAMADOS -->
        <div class="history-column">
            <h2 style="font-family: 'Space Grotesk', sans-serif; font-size: 2rem; margin-bottom: 5px; color: #fff;">Meu Histórico</h2>
            <p style="color: #aaa; margin-bottom: 30px;">Acompanhe o andamento das suas solicitações.</p>

            <% if (chamados && chamados.length > 0) { %>
                <% chamados.forEach(chamado => { %>
                    <% const precisaAtencao = (chamado.status === 'pendente_cliente' || chamado.status === 'em_andamento'); %>
                    <div class="history-card" style="<%= precisaAtencao ? 'border-left: 4px solid #00aaff; background: rgba(0, 170, 255, 0.05);' : 'border-left: 4px solid transparent;' %>">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                            <h3 style="margin: 0; color: #fff; font-size: 1.1rem; font-weight: 700;"><%= chamado.titulo %></h3>
                            
                            <!-- TRADUÇÃO INTUITIVA DE STATUS -->
                            <% 
                                let labelStatus = 'Recebido';
                                let classStatus = 'status-recebido';
                                
                                if (chamado.status === 'em_andamento') { labelStatus = 'Em Andamento'; classStatus = 'status-em_andamento'; }
                                else if (chamado.status === 'pendente_cliente') { labelStatus = 'Aguardando Você'; classStatus = 'status-pendente_cliente'; }
                                else if (chamado.status === 'pendente_terceiro') { labelStatus = 'Em Análise Externa'; classStatus = 'status-pendente_terceiro'; }
                                else if (chamado.status === 'atrasado') { labelStatus = 'Em Atraso (Crítico)'; classStatus = 'status-atrasado'; }
                                else if (chamado.status === 'resolvido') { labelStatus = 'Finalizado'; classStatus = 'status-resolvido'; }
                                else if (chamado.status === 'cancelado') { labelStatus = 'Cancelado'; classStatus = 'status-recebido'; }
                            %>
                            <span class="status-badge <%= classStatus %>"><%= labelStatus %></span>
                        </div>
                        
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 15px;">
                            <div style="display: flex; gap: 15px; font-size: 0.8rem; color: #888;">
                                <span><strong style="font-weight: 500;">Data:</strong> <%= new Date(chamado.criado_em).toLocaleDateString('pt-BR') %></span>
                                <span style="color: var(--brand-upgrade);"><strong style="font-weight: 600;">Prioridade:</strong> <%= chamado.prioridade %></span>
                                <span><strong style="font-weight: 500;">Ref:</strong> #<%= String(chamado.id).substring(0,6) %></span>
                            </div>
                            <button onclick="abrirChatCliente('<%= chamado.id %>', '<%= chamado.titulo %>')" style="background: transparent; color: var(--primary); border: 1px solid var(--primary); padding: 5px 15px; border-radius: 4px; cursor: pointer; font-size: 0.8rem; font-weight: bold; transition: 0.3s;" onmouseover="this.style.background='var(--primary)'; this.style.color='#000';" onmouseout="this.style.background='transparent'; this.style.color='var(--primary)';">💬 Ver Chat</button>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="text-align: center; padding: 50px 20px; background: rgba(0,0,0,0.4); border-radius: 10px; border: 1px dashed rgba(255,255,255,0.2);">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="1.5" style="margin-bottom: 15px;">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="9" y1="3" x2="9" y2="21"></line>
                    </svg>
                    <h3 style="color: #fff; margin-bottom: 10px;">Nenhum chamado encontrado</h3>
                    <p style="color: #888; font-size: 0.9rem;">Você ainda não possui solicitações de suporte ativas. Quando abrir um chamado, ele aparecerá aqui.</p>
                </div>
            <% } %>
        </div>

    </div>

    <%- include('../partials/footer') %>

<script>
    function calcularPrioridade() {
        const impacto = parseInt(document.getElementById('impacto').value);
        const urgencia = parseInt(document.getElementById('urgencia').value);
        let prioridade = "P4";
        let cor = "#444";
        let texto = "P4 - Baixa Prioridade";
        const soma = impacto + urgencia;
        
        if (soma === 2) { prioridade = "P1"; cor = "#ff0033"; texto = "P1 - Crítico (2h)"; } 
        else if (soma === 3 || soma === 4) { prioridade = "P2"; cor = "#ff8800"; texto = "P2 - Alto (8h)"; } 
        else if (soma === 5) { prioridade = "P3"; cor = "#ffcc00"; texto = "P3 - Médio (24h)"; } 
        else { prioridade = "P4"; cor = "#33aa33"; texto = "P4 - Planejado (7 dias)"; }

        const badge = document.getElementById('badge-prioridade');
        badge.style.backgroundColor = cor;
        badge.style.color = (prioridade === 'P3') ? '#000' : '#fff';
        badge.innerText = texto;
        document.getElementById('input-prioridade').value = prioridade;
    }
    calcularPrioridade();
</script>

<!-- Modal de Chat do Cliente -->
<div id="modalChatCliente" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); z-index: 2000; display: none; justify-content: center; align-items: center;">
    <div style="background: #111; width: 90%; max-width: 600px; height: 70vh; border: 1px solid var(--primary); border-radius: 12px; display: flex; flex-direction: column;">
        <div style="padding: 20px; border-bottom: 1px solid rgba(255,255,255,0.1); display: flex; justify-content: space-between;">
            <h3 style="color: #fff;" id="chatTituloCliente">Comunicações</h3>
            <button onclick="fecharChatCliente()" style="background: none; border: none; color: #fff; font-size: 1.5rem; cursor: pointer;">×</button>
        </div>
        
        <div id="areaMensagensCliente" style="flex: 1; padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 15px;">
            <!-- Renderizado via JS -->
        </div>

        <div style="padding: 20px; border-top: 1px solid rgba(255,255,255,0.1); display: flex; gap: 10px;">
            <input type="text" id="inputMsgCliente" placeholder="Escreva para o desenvolvedor..." style="flex: 1; background: #222; border: 1px solid #444; color: #fff; padding: 12px; border-radius: 6px;" onkeypress="if(event.key === 'Enter') enviarMsgCliente()">
            <button onclick="enviarMsgCliente()" style="background: var(--primary); color: #000; border: none; padding: 0 20px; border-radius: 6px; font-weight: bold; cursor: pointer;">Enviar</button>
        </div>
    </div>
</div>

<script>
    let chamadoAtivoCliente = null;

    async function abrirChatCliente(id, titulo) {
        chamadoAtivoCliente = id;
        document.getElementById('modalChatCliente').style.display = 'flex';
        document.getElementById('chatTituloCliente').innerText = titulo;
        document.getElementById('areaMensagensCliente').innerHTML = '<p style="color: #888; text-align: center;">Carregando...</p>';
        
        try {
            const res = await fetch('/api/chamados/' + id);
            const data = await res.json();
            renderizarMensagens(data.interacoes);
        } catch(e) {
            console.error(e);
        }
    }

    function fecharChatCliente() {
        document.getElementById('modalChatCliente').style.display = 'none';
        chamadoAtivoCliente = null;
    }

    function renderizarMensagens(interacoes) {
        const area = document.getElementById('areaMensagensCliente');
        area.innerHTML = '';
        if(!interacoes || interacoes.length === 0) {
            area.innerHTML = '<p style="color: #555; text-align: center; margin-top: 50px;">O desenvolvedor ainda não respondeu.</p>';
            return;
        }

        interacoes.forEach(int => {
            const eu = int.usuario_id === '<%= user ? user.id : "" %>';
            const div = document.createElement('div');
            
            div.style.maxWidth = '80%';
            div.style.padding = '12px 18px';
            div.style.borderRadius = '8px';
            div.style.lineHeight = '1.4';
            div.style.fontSize = '0.95rem';

            if (eu) {
                div.style.alignSelf = 'flex-end';
                div.style.background = 'rgba(255, 255, 255, 0.1)';
                div.style.border = '1px solid rgba(255, 255, 255, 0.2)';
                div.style.textAlign = 'right';
                div.style.color = '#fff';
            } else {
                div.style.alignSelf = 'flex-start';
                div.style.background = 'rgba(0, 255, 136, 0.15)';
                div.style.border = '1px solid var(--primary)';
                div.style.color = '#fff';
            }

            const nome = int.nome_autor || 'Usuário';
            const dataHora = new Date(int.criado_em).toLocaleString('pt-BR');

            div.innerHTML = `
                <div style="font-size: 0.75rem; color: #ccc; margin-bottom: 5px; opacity: 0.9;">
                    ${eu ? 'Você' : nome} • ${dataHora}
                </div>
                <div>${int.mensagem}</div>
            `;
            area.appendChild(div);
        });
        area.scrollTop = area.scrollHeight;
    }

    async function enviarMsgCliente() {
        const input = document.getElementById('inputMsgCliente');
        const msg = input.value.trim();
        if(!msg || !chamadoAtivoCliente) return;

        input.disabled = true;
        input.value = 'Enviando...';

        try {
            const res = await fetch('/api/chamados/' + chamadoAtivoCliente + '/interacao', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ mensagem: msg })
            });
            if(res.ok) {
                input.value = '';
                abrirChatCliente(chamadoAtivoCliente, document.getElementById('chatTituloCliente').innerText);
            }
        } catch(e) {
            alert('Erro ao enviar mensagem');
        } finally {
            input.disabled = false;
            input.focus();
        }
    }
</script>

</body>
</html>
