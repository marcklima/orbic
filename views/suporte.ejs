<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Orbic | Portal do Cliente</title>
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .portal-header {
            text-align: center;
            margin-bottom: 50px;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(0, 255, 136, 0.2);
            border-radius: 15px;
            padding: 40px;
            transition: 0.3s;
            text-align: center;
        }
        .glass-card:hover {
            border-color: var(--primary);
            box-shadow: 0 0 20px rgba(0, 255, 136, 0.1);
            transform: translateY(-5px);
        }
        .container-portal {
            padding: 120px 10%;
            min-height: 80vh;
        }
        .grid-layout {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            max-width: 1000px;
            margin: 0 auto;
        }
        .btn-portal {
            display: inline-block;
            margin-top: 25px;
            padding: 15px 30px;
            background: var(--primary);
            color: #000;
            text-decoration: none;
            font-weight: 800;
            border-radius: 6px;
            text-transform: uppercase;
            transition: 0.3s;
        }
        .btn-portal:hover {
            box-shadow: 0 0 20px var(--primary);
            transform: scale(1.05);
        }
        .icon-large {
            font-size: 3rem;
            margin-bottom: 15px;
            color: var(--primary);
        }
    </style>
</head>
<body class="tech-bg">

    <%- include('partials/navbar') %>

    <main class="container-portal">
        <header class="portal-header">
            <h1 style="font-family: 'Space Grotesk', sans-serif; font-size: 3rem; margin-bottom: 10px;">Portal do Cliente</h1>
            <p style="color: #aaa; font-size: 1.1rem;">Bem-vindo(a), <strong style="color: var(--primary);"><%= user.nome %></strong>. Como podemos ajudar hoje?</p>
        </header>

        <section class="grid-layout">
            <!-- Bloco de Chamados ITIL -->
            <div class="glass-card">
                <div class="icon-large">🎧</div>
                <h3 style="font-family: 'Space Grotesk', sans-serif; font-size: 1.5rem; margin-bottom: 10px;">Suporte & Chamados</h3>
                <p style="color: #888;">Abra novas solicitações técnicas, agende suportes remotos e acompanhe o andamento do seu histórico.</p>
                <a href="<%= user.email === 'palavraevidaonline@gmail.com' ? '/upgrade/gestao' : '/upgrade/chamados' %>" class="btn-portal">Acessar Dashboard</a>
            </div>

            <!-- Bloco Zents (Condicional) -->
            <% if (user && (user.role === 'zents' || user.role === 'admin' || user.empresa === 'Zents')) { %>
            <div class="glass-card" style="border-color: #1db954;">
                <div class="icon-large" style="color: #1db954;">⚙️</div>
                <h3 style="color: #1db954; font-family: 'Space Grotesk', sans-serif; font-size: 1.5rem; margin-bottom: 10px;">Painel Zents (Gestão)</h3>
                <p style="color: #888;">Gestão exclusiva de tarefas corporativas e integrações do sistema Zents.</p>
                <a href="/upgrade/gestao" class="btn-portal" style="background: #1db954; color: #000;">Acessar Gestão</a>
            </div>
            <% } %>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script src="/js/main.js"></script>
</body>
</html>
