<style>
    .dropdown {
        position: relative;
        display: inline-block;
    }
    .dropdown-content {
        display: none;
        position: absolute;
        background-color: #111;
        min-width: 160px;
        box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.5);
        z-index: 1000;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 4px;
        top: 100%;
        left: 0;
    }
    .dropdown-content a {
        color: #fff;
        padding: 12px 16px;
        text-decoration: none;
        display: block;
        font-size: 0.9rem;
        margin-left: 0 !important;
    }
    .dropdown-content a:hover {
        background-color: rgba(255,255,255,0.1);
        color: var(--primary);
    }
    .dropdown:hover .dropdown-content {
        display: block;
    }
</style>
<nav>
    <a href="/" class="logo">ORBIC</a>
    <div class="nav-links" style="display: flex; align-items: center;">
        <% if (typeof user !== 'undefined' && user && (user.email === 'palavraevidaonlina@gmail.com' || user.email === 'palavraevidaonline@gmail.com' || user.role === 'admin')) { %>
        <div class="dropdown">
            <a href="#" class="dropbtn" style="color: #aaa;">Em Produção ▼</a>
            <div class="dropdown-content">
                <a href="/intellect">Intellect</a>
                <a href="/hubimb">Hubimb</a>
                <a href="/videobook">Video Book</a>
            </div>
        </div>
        <% } %>
        <% if (user) { %>
            <% if (user.role !== 'zents' && user.role !== 'suporte_l1') { %>
            <a href="/suporte">Suporte</a>
            <% } %>
            <% if (user.email !== 'palavraevidaonline@gmail.com' && user.role !== 'suporte_l1') { %>
            <a href="/upgrade/chamados">Meus Chamados</a>
            <% } %>
            <% if (user.role === 'admin' || user.role === 'suporte_l1') { %>
                <a href="/upgrade/gestao" style="color: #00f2ff; font-weight: bold;">Gestão ITIL</a>
            <% } %>
            <% if (user.role === 'admin' || user.role === 'zents') { %>
                <a href="/financeiro">Financeiro</a>
            <% } %>
            <% if (user.email === 'palavraevidaonline@gmail.com') { %>
                <a href="/upgrade/admin/usuarios" style="color: #ff3366; font-weight: bold;">Usuários</a>
            <% } %>
            <a href="/upgrade" style="color: var(--primary); text-shadow: 0 0 5px var(--primary); border: 1px solid var(--primary); padding: 4px 12px; border-radius: 4px;">UPGRADE</a>
            
            <div style="display: flex; align-items: center; margin-left: 30px; border-left: 1px solid rgba(255,255,255,0.2); padding-left: 20px;">
                <% if (user.picture) { %>
                    <img src="<%= user.picture %>" alt="User" style="width: 30px; height: 30px; border-radius: 50%; border: 1px solid var(--primary); margin-right: 10px;">
                <% } %>
                <span style="font-size: 0.8rem; font-family: 'Space Grotesk', sans-serif; margin-right: 15px;"><%= user.nome.split(' ')[0] %></span>
                <a href="/auth/logout" style="color: #ff3366; border: 1px solid #ff3366; padding: 4px 10px; border-radius: 4px; margin-left: 0;">Sair</a>
            </div>
        <% } else { %>
            <a href="#contato">Contato</a>
            <a href="/auth/login/google" style="color: #fff; background: transparent; border: 1px solid rgba(255,255,255,0.3); padding: 6px 18px; border-radius: 4px; font-weight: 500; font-size: 0.9rem; margin-left: 30px; display: flex; align-items: center; gap: 8px; transition: 0.3s; text-decoration: none;" onmouseover="this.style.borderColor='var(--primary)'; this.style.color='var(--primary)';" onmouseout="this.style.borderColor='rgba(255,255,255,0.3)'; this.style.color='#fff';">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                Login
            </a>
        <% } %>
    </div>
</nav>